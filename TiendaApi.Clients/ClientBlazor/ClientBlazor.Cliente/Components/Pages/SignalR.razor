@page "/signalr"
@using ClientBlazor.Cliente.Components.Shared
@using ClientBlazor.Cliente.Configuration
@using ClientBlazor.Cliente.Services.SignalR
@using ClientBlazor.Cliente.State
@using System.Text.Json
@implements IAsyncDisposable

@inject ISignalRService SignalRService
@inject INotificationStore NotificationStore

<NavMenu />

<div class="config-section">
    <h3 class="section-title">SignalR Hub Client</h3>
    <p style="color: var(--hk-red); margin-bottom: 15px;">
        Cliente SignalR Hub para comunicacion en tiempo real
    </p>

    <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: stretch; margin-bottom: 15px;">
        <select @bind="selectedHubType" @bind:after="OnSelectedHubTypeChanged" style="min-width: 200px; height: 50px; padding: 12px 15px; border: 3px solid var(--hk-light-pink); border-radius: 25px; font-size: 1em; font-family: 'Balsamiq Sans', cursive; background: white; box-sizing: border-box;">
            <option value="productos">📦 Productos (Publico)</option>
            <option value="pedidos">🛒 Pedidos (Requiere JWT)</option>
        </select>

        <button class="btn-quick" style="min-width: 180px; height: 50px; box-sizing: border-box; font-family: 'Balsamiq Sans', cursive; font-size: 1em;" @onclick="ConnectAsync" disabled="@SignalRService.IsConnected">
            @(SignalRService.IsConnected ? "🔴 Hub Activo" : "▶️ Conectar Hub")
        </button>

        <button class="btn-quick" style="min-width: 180px; height: 50px; box-sizing: border-box; font-family: 'Balsamiq Sans', cursive; font-size: 1em;" @onclick="DisconnectAsync" disabled="@(!SignalRService.IsConnected)">
            ⏹️ Desconectar Hub
        </button>

        <button class="btn-quick" style="min-width: 100px; height: 50px; box-sizing: border-box; font-family: 'Balsamiq Sans', cursive; font-size: 1em;" @onclick="ClearMessages">
            🧹 Limpiar
        </button>
    </div>

    @if (selectedHubType == "pedidos")
    {
        <p style="color: var(--hk-red); text-align: center; font-weight: bold; margin-top: 10px;">
            🔐 Los SignalR Hubs de pedidos requieren autenticacion JWT
        </p>
    }
</div>

<div class="response-section">
    <h3 class="section-title">Estado del Hub</h3>
    <div class="response-display" style="color: @(SignalRService.IsConnected ? "var(--hk-green)" : "var(--hk-red)"); font-weight: bold;">
        Estado: @(SignalRService.IsConnected ? "🟢 Hub Conectado" : "🔴 Hub Desconectado") - Tipo: @selectedHubType.ToUpper()
    </div>
</div>

<div class="response-section">
    <h3 class="section-title">Mensajes Recibidos</h3>
    <div class="response-display">
        <pre style="white-space: pre-wrap; font-family: 'Balsamiq Sans', cursive; max-height: 400px; overflow-y: auto; min-height: 100px;">@(SignalRService.IsConnected ? (string.IsNullOrEmpty(messages) ? "Esperando mensajes del Hub..." : messages) : "Desconectado")</pre>
    </div>
</div>

<div class="info-box">
    <h4>SignalR Events</h4>
    <p><b>Productos (Publico):</b></p>
    <p>• <code>ProductoCreado</code> - Se crea un nuevo producto</p>
    <p>• <code>ProductoActualizado</code> - Se actualiza un producto</p>
    <p>• <code>ProductoEliminado</code> - Se elimina un producto</p>
    <p>• <code>StockBajo</code> - El stock de un producto esta bajo</p>
    <p><b>Pedidos (JWT requerido):</b></p>
    <p>• <code>PedidoCreado</code> - Se crea un nuevo pedido</p>
    <p>• <code>PedidoActualizado</code> - Se actualiza el estado de un pedido</p>
    <p><b>Protocolo:</b> SignalR (WebSocket + fallback)</p>
    <p><b>Nota:</b> Los eventos llegan automaticamente al conectarse al Hub, sin suscripciones especificas.</p>
</div>

@code {
    private string selectedHubType = "productos";
    private string messages = "";

    protected override void OnInitialized()
    {
        SignalRService.OnMessageReceived += HandleMessageReceived;
    }

    private async Task ConnectAsync()
    {
        if (selectedHubType == "productos")
        {
            await SignalRService.ConnectProductosAsync();
        }
        else if (selectedHubType == "pedidos")
        {
            await SignalRService.ConnectPedidosAsync();
        }
        StateHasChanged();
    }

    private async Task DisconnectAsync()
    {
        await SignalRService.DisconnectAsync();
        StateHasChanged();
    }

    private void ClearMessages()
    {
        messages = "";
        StateHasChanged();
    }

    private void HandleMessageReceived(string message)
    {
        var timestamp = DateTime.Now.ToString("HH:mm:ss");
        messages += "[" + timestamp + "] " + message + "\n";

        // Limitar el numero de mensajes mostrados (ultimos 50)
        var lines = messages.Split('\n');
        if (lines.Length > 50)
        {
            messages = string.Join('\n', lines.Skip(lines.Length - 50));
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task OnSelectedHubTypeChanged()
    {
        if (SignalRService.IsConnected)
        {
            await SignalRService.DisconnectAsync();
        }
        messages = "";
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        SignalRService.OnMessageReceived -= HandleMessageReceived;
        await SignalRService.DisconnectAsync();
    }
}
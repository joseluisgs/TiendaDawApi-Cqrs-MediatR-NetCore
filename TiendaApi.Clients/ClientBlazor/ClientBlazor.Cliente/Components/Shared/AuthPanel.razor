@using ClientBlazor.Cliente.State.Auth
@using ClientBlazor.Cliente.Services.Rest
@implements IDisposable
@inject IAuthStore AuthStore
@inject IAuthService AuthService

@if (isAuthenticated)
{
    <div class="auth-panel" data-testid="auth-panel">
        <div class="auth-card">
            <div class="auth-header">
                <span class="auth-bow">🎀</span>
                <span class="auth-greeting">@displayName</span>
                <span class="auth-bow flip">🎀</span>
            </div>
            
            <div class="auth-details">
                <div class="detail-item">
                    <span class="detail-icon">📧</span>
                    <span class="detail-email">@email</span>
                </div>
                <div class="detail-item">
                    <span class="detail-icon">🔑</span>
                    <span class="detail-role @(isAdmin ? "role-admin" : "role-user")">@role</span>
                </div>
            </div>
            
            <button class="auth-logout-btn" @onclick="Logout">
                Cerrar Sesión
            </button>
        </div>
    </div>
}

@code {
    /// <summary>Indica si el usuario actual está logueado en el sistema.</summary>
    private bool isAuthenticated = false;
    /// <summary>Indica si el usuario tiene privilegios de administrador.</summary>
    private bool isAdmin = false;
    /// <summary>Email del usuario autenticado.</summary>
    private string email = "";
    /// <summary>Rol textual del usuario.</summary>
    private string role = "";
    /// <summary>Nombre o pseudónimo a mostrar en el saludo.</summary>
    private string displayName = "";
    
    /// <summary>Lista de suscripciones reactivas para gestión de memoria.</summary>
    private readonly List<IDisposable> subscriptions = new();

    /// <summary>
    /// Suscribe el componente a todos los campos relevantes del AuthStore al iniciar.
    /// </summary>
    protected override void OnInitialized()
    {
        subscriptions.Add(AuthStore.IsAuthenticatedObservable.Subscribe(auth => {
            isAuthenticated = auth;
            InvokeAsync(StateHasChanged);
        }));

        subscriptions.Add(AuthStore.IsAdminObservable.Subscribe(admin => {
            isAdmin = admin;
            InvokeAsync(StateHasChanged);
        }));

        subscriptions.Add(AuthStore.EmailObservable.Subscribe(e => {
            email = e;
            InvokeAsync(StateHasChanged);
        }));

        subscriptions.Add(AuthStore.RoleObservable.Subscribe(r => {
            role = r;
            InvokeAsync(StateHasChanged);
        }));

        subscriptions.Add(AuthStore.DisplayNameObservable.Subscribe(name => {
            displayName = name;
            InvokeAsync(StateHasChanged);
        }));
    }

    /// <summary>
    /// Invoca el proceso de cierre de sesión mediante el servicio de autenticación.
    /// </summary>
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
    }

    /// <summary>
    /// Libera los recursos y cancela las suscripciones activas al destruir el componente.
    /// </summary>
    public void Dispose()
    {
        foreach (var sub in subscriptions) sub.Dispose();
        subscriptions.Clear();
    }
}
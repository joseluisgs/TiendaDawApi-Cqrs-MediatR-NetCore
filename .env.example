# ============================================
# CONFIGURACIÓN DE TIENDA API - PRODUCCIÓN
# ============================================
# Copia este archivo a .env y completa los valores
# IMPORTANTE: Las variables de entorno en .NET usan
# DOBLE GUION BAJO (__) en lugar de dos puntos (:)
#
# Ejemplo: Jwt:Key → Jwt__Key
#          ConnectionStrings:Redis → ConnectionStrings__Redis
# ============================================

# ============================================
# JWT - Autenticación
# ============================================
# Clave JWT (mínimo 256 bits = 32 caracteres)
# Si no se define, usa el valor por defecto (que debes cambiar)
Jwt__Key=CAMBIAR_POR_CLAVE_SEGURA_MINIMO_32_CARACTERES
Jwt__Issuer=TiendaApi
Jwt__Audience=TiendaApi
Jwt__ExpireMinutes=30

# ============================================
# CONNECTION STRINGS - Bases de datos
# ============================================
# PostgreSQL (categorías, productos, usuarios)
ConnectionStrings__DefaultConnection=Host=postgres;Database=tienda;Username=admin;Password=admin123

# MongoDB (pedidos)
ConnectionStrings__MongoDB=mongodb://admin:admin123@mongodb:27017/tienda?authSource=admin

# Redis (cache)
ConnectionStrings__Redis=redis:6379

# ============================================
# MONGODB SETTINGS
# ============================================
MongoDbSettings__ConnectionString=mongodb://admin:admin123@mongodb:27017/tienda?authSource=admin
MongoDbSettings__DatabaseName=tienda
MongoDbSettings__PedidosCollection=pedidos

# ============================================
# SMTP - Envío de emails
# ============================================
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=noreply@tienda.com
Smtp__FromName=TiendaApi Notifications
Smtp__AdminEmail=admin@tienda.com
Smtp__EnableSsl=true

# ============================================
# CACHE
# ============================================
Cache__DefaultExpirationMinutes=5
Cache__ProductoCacheTTLMinutes=10

# ============================================
# WEBSOCKET
# ============================================
WebSocket__RoleCacheTTLMinutes=3

# ============================================
# STORAGE - Subida de archivos
# ============================================
Storage__UploadPath=images/uploads
Storage__MaxFileSize=5242880

# ============================================
# PEDIDOS - Repositorio de MongoDB
# Valores: MongoDbNative (driver nativo), MongoDbEfCore (Entity Framework Core, tiene bug)
Pedidos__RepositoryType=MongoDbNative

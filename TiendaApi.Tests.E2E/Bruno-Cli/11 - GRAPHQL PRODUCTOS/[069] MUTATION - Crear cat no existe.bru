meta {
  name: [069] MUTATION - Crear cat no existe
  type: graphql
  seq: 6
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:graphql {
  mutation($input: CreateProductoInput!) { createProducto(input: $input) { id nombre } }
}

body:graphql:vars {
  {"input": {"nombre": "Test", "precio": 99, "stock": 10, "categoriaId": 999999}}
}

script:post-response {
  test("GraphQL CreateProducto NotFound - Returns error", function () {
      const jsonData = res.getBody();
      expect(jsonData.errors).to.be.an('array');
      expect(jsonData.errors[0].message).to.include('NOT_FOUND');
  });
}

settings {
  encodeUrl: true
}

docs {
  GraphQL: Crear producto con categoría inexistente debe fallar
}

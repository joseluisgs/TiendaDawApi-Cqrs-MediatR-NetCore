# Entorno de pruebas Bruno para TiendaApi .NET

# URL base de la API
# Usar http://api:8080 si se ejecuta dentro de la red de docker o http://host.docker.internal:5031 si es desde un contenedor hacia el host
baseUrl=http://host.docker.internal:5031

# Credenciales de administrador
adminUsername=admin
adminPassword=admin

# Credenciales de usuario normal
userUsername=userdaw
userPassword=userdaw

# Tokens (se establecen durante la ejecución de tests)

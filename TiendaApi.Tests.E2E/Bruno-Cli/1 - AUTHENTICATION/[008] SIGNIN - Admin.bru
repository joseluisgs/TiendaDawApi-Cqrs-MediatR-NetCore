meta {
  name: [008] SIGNIN - Admin
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/auth/signin
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
      "username": "{{adminUsername}}",
      "password": "{{adminPassword}}"
  }
}

script:post-response {
  test("Signin Admin - Status 200 OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("Signin Admin - Has token", function () {
      const jsonData = res.getBody();
      expect(jsonData.token).to.not.be.empty;
      expect(jsonData.user).to.be.an('object');
  });
  
  test("Signin Admin - Role is ADMIN", function () {
      const jsonData = res.getBody();
      expect(jsonData.user.role).to.equal('ADMIN');
  });
  
  // Guardar token de admin
  if (res.getStatus() === 200) {
      const jsonData = res.getBody();
      bru.setVar("adminToken", jsonData.token);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Login de administrador. Happy path.
}

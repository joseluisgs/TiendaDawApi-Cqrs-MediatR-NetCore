meta {
  name: [003] SIGNUP - Error username
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/signup
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
      "username": "",
      "email": "test@test.com",
      "password": "Test1234"
  }
}

script:post-response {
  test("Signup validation - Status 400 Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  test("Signup validation - Has error message", function () {
      const jsonData = res.getBody();
      expect(jsonData.message).to.not.be.empty;
  });
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Signup con username vacío debe retornar 400
}

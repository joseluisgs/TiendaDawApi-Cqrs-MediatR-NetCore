meta {
  name: [009] SIGNIN - Error credenciales
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/auth/signin
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
      "username": "{{adminUsername}}",
      "password": "wrongpassword"
  }
}

script:post-response {
  test("Signin invalid - Status 401 Unauthorized", function () {
      expect(res.getStatus()).to.equal(401);
  });
  
  test("Signin invalid - Has error message", function () {
      const jsonData = res.getBody();
      expect(jsonData.message).to.not.be.empty;
  });
}

settings {
  encodeUrl: true
}

docs {
  Login con contraseña incorrecta debe retornar 401
}

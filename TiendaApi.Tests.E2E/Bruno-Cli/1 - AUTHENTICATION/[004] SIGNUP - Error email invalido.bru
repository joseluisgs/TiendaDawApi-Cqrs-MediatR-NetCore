meta {
  name: [004] SIGNUP - Error email
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/signup
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
      "username": "testuser",
      "email": "email-invalido",
      "password": "Test1234"
  }
}

script:post-response {
  test("Signup invalid email - Status 400 Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Signup con email inválido debe retornar 400
}

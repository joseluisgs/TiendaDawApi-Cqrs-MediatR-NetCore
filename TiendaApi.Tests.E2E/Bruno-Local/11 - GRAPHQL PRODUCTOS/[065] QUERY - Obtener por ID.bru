meta {
  name: [065] QUERY - Obtener por ID
  type: graphql
  seq: 2
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query($id: Long!) { producto(id: $id) { id nombre precio stock categoria { nombre } } }
}

body:graphql:vars {
  {"id": 1}
}

script:post-response {
  test("GraphQL ProductoById - Status 200 OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GraphQL ProductoById - Returns producto", function () {
      const jsonData = res.getBody();
      expect(jsonData.data.producto).to.be.an('object');
      expect(jsonData.data.producto.id).to.be.a('number');
      expect(jsonData.data.producto.nombre).to.be.a('string');
  });
}

settings {
  encodeUrl: true
}

docs {
  GraphQL: Obtiene producto por ID (público)
}

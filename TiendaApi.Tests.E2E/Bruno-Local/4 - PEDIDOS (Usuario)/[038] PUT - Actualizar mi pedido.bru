meta {
  name: [038] PUT - Actualizar mi pedido
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/pedidos/me/{{pedidoId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{userToken}}
}

body:json {
  {
      "direccionEnvio": "Actualizado desde tests E2E"
  }
}

script:post-response {
  test("Pedidos My Update - Status 200 OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("Pedidos My Update - Returns updated pedido", function () {
      const jsonData = res.getBody();
      expect(jsonData).to.be.an('object');
      expect(jsonData.estado).to.equal('PENDIENTE');
  });
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Actualiza pedido propio. Solo permite modificar pedidos en estado PENDIENTE.
}

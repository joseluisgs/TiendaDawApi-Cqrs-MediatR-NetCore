# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN - TIENDA API
# ============================================
# Copia este archivo a .env y configura los valores
# Las variables con valores por defecto no son obligatorias
# ============================================

# ============================================
# DOMINIO (para Traefik)
# ============================================
DOMAIN=tienda.local

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_DB=tienda
POSTGRES_USER=admin
POSTGRES_PASSWORD=ChangeThisSecurePassword123!
POSTGRES_PORT=5432

# Límites de recursos (opcional)
POSTGRES_CPUS=1
POSTGRES_MEMORY=512M
POSTGRES_CPUS_RESERVED=0.5
POSTGRES_MEMORY_RESERVED=256M

# ============================================
# MONGODB
# ============================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=ChangeThisSecurePassword123!
MONGO_DB=tienda
MONGO_PORT=27017
MONGO_PEDIDOS_COLLECTION=pedidos

# Límites de recursos (opcional)
MONGO_CPUS=1
MONGO_MEMORY=512M
MONGO_CPUS_RESERVED=0.5
MONGO_MEMORY_RESERVED=256M

# ============================================
# REDIS
# ============================================
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# Límites de recursos (opcional)
REDIS_CPUS=0.5
REDIS_MEMORY=256M
REDIS_CPUS_RESERVED=0.25
REDIS_MEMORY_RESERVED=128M

# ============================================
# API .NET
# ============================================
API_PORT=5000
BUILD_CONFIGURATION=Release

# JWT - IMPORTANTE: Cambiar en producción
JWT_KEY=ChangeThisToASuperSecureKeyAtLeast32CharactersLong!!!
JWT_ISSUER=TiendaApi
JWT_AUDIENCE=TiendaApi
JWT_EXPIRE_MINUTES=30

# ============================================
# SMTP - Envío de emails
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM_EMAIL=noreply@tienda.com
SMTP_FROM_NAME=TiendaApi Notifications
SMTP_ADMIN_EMAIL=admin@tienda.com
SMTP_ENABLE_SSL=true

# ============================================
# CACHE
# ============================================
CACHE_DEFAULT_EXPIRATION_MINUTES=5
CACHE_PRODUCTO_TTL_MINUTES=10

# ============================================
# WEBSOCKET
# ============================================
WEBSOCKET_ROLE_CACHE_TTL_MINUTES=3

# ============================================
# STORAGE - Subida de archivos
# ============================================
STORAGE_UPLOAD_PATH=uploads
STORAGE_MAX_FILE_SIZE=5242880

# Límites de recursos (opcional)
API_CPUS=1
API_MEMORY=512M
API_CPUS_RESERVED=0.5
API_MEMORY_RESERVED=256M

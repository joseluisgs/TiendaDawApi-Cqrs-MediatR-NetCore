{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Application": {
    "Name": "TiendaApi",
    "Version": "1.0.0",
    "Culture": "es-ES",
    "Description": "API REST educativa - Entorno de Producción"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=tienda;Username=admin;Password=admin123",
    "MongoDB": "mongodb://admin:admin123@mongodb:27017/tienda?authSource=admin",
    "Redis": "redis:6379"
  },
  "MongoDbSettings": {
    "ConnectionString": "mongodb://admin:admin123@mongodb:27017/tienda?authSource=admin",
    "DatabaseName": "tienda",
    "PedidosCollection": "pedidos"
  },
  "Jwt": {
    "Key": "CLAVE_JWT_POR_DEFECTO_CAMBIAR_EN_PRODUCCION",
    "Issuer": "TiendaApi",
    "Audience": "TiendaApi",
    "ExpireMinutes": "30"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@tienda.com",
    "FromName": "TiendaApi Notifications",
    "AdminEmail": "admin@tienda.com",
    "EnableSsl": true
  },
  "Cache": {
    "DefaultExpirationMinutes": "5",
    "ProductoCacheTTLMinutes": "10"
  },
  "Storage": {
    "UploadPath": "images/uploads",
    "MaxFileSize": 5242880,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/gif"]
  },
  "Database": {
    "Seed": {
      "AlwaysSeed": false,
      "Description": "En producción solo siembra datos si no existen tablas"
    }
  },
  "WebSocket": {
    "RoleCacheTTLMinutes": "3",
    "Description": "TTL para caché de roles de WebSocket (producción)"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://tienda.example.com",
      "https://www.tienda.example.com"
    ],
    "Description": "Orígenes permitidos en producción. Añadir dominios de clientes web."
  },
  "Scheduler": {
    "Enabled": true,
    "ProductoReportDays": 7,
    "ExecutionIntervalMinutes": 1,
    "ExecutionIntervalHours": 168
  },
  "Pedidos": {
    "RepositoryType": "MongoDbNative",
    "Description": "Tipo de repositorio para pedidos. MongoDbNative = driver nativo (funcional), MongoDbEfCore = EF Core (bug EF-272)"
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Application": {
    "Name": "TiendaApi",
    "Version": "1.0.0",
    "Culture": "es-ES",
    "Description": "API REST educativa - Entorno de Desarrollo"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tienda;Username=admin;Password=admin123",
    "MongoDB": "mongodb://admin:admin123@localhost:27017/tienda?authSource=admin",
    "Redis": "localhost:6379"
  },
  "MongoDbSettings": {
    "ConnectionString": "mongodb://admin:admin123@localhost:27017/tienda?authSource=admin",
    "DatabaseName": "tienda",
    "PedidosCollection": "pedidos"
  },
  "Jwt": {
    "Key": "Me-Gustan-Los-Pepinos-De-Leganes-Porque-Son-Grandes-Y-Hermosos-Como-Los-De-Carlos-Y-Su-Huerta!",
    "Issuer": "TiendaApi",
    "Audience": "TiendaApi",
    "ExpireMinutes": "60"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@tienda.com",
    "FromName": "TiendaApi Notifications",
    "AdminEmail": "admin@tienda.com",
    "EnableSsl": true
  },
  "Cache": {
    "DefaultExpirationMinutes": "5",
    "ProductoCacheTTLMinutes": "10"
  },
  "Storage": {
    "UploadPath": "images/uploads",
    "MaxFileSize": 5242880,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/gif"]
  },
  "Database": {
    "Seed": {
      "AlwaysSeed": true,
      "Description": "En desarrollo siempre se siembran los datos种子"
    }
  },
  "WebSocket": {
    "RoleCacheTTLMinutes": "5",
    "Description": "TTL para caché de roles de WebSocket (desarrollo)"
  },
  "Scheduler": {
    "Enabled": true,
    "ProductoReportDays": 7,
    "ExecutionIntervalMinutes": 1,
    "ExecutionIntervalHours": 168
  },
  "Pedidos": {
    "RepositoryType": "MongoDbNative",
    "Description": "Tipo de repositorio para pedidos. MongoDbNative = driver nativo (funcional), MongoDbEfCore = EF Core (bug EF-272)"
  }
}
